{
  "role_id": "release-manager",
  "role_email": "release-manager@example.com",
  "mail_account": {
    "profile": "release-manager",
    "email": "release-manager@example.com"
  },
  "request_authentication": {
    "allowed_sender_emails": [
      "release-gate@example.com"
    ],
    "allowed_authserv_ids": [
      "mx.example.com"
    ],
    "accepted_paths": [
      "dmarc",
      "dkim",
      "spf"
    ]
  },
  "release_group": "release-approvers@example.com",
  "mailbox": "INBOX",
  "page": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "poll_minutes": 60,
  "timezone": "Asia/Shanghai",
  "working_hours": {
    "days": [
      "Mon",
      "Tue",
      "Wed",
      "Thu",
      "Fri"
    ],
    "start": "09:00",
    "end": "18:00"
  },
  "state_dir": "%LOCALAPPDATA%\\release-approval\\state",
  "dependency_lock": "%RELEASE_APPROVAL_REPO_ROOT%\\dependency-lock.json",
  "audit": {
    "verify_chain_on_startup": true,
    "retention_days": 3650,
    "document_url": ""
  }
