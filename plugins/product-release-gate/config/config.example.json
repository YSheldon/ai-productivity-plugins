{
  "storage_dir": "%USERPROFILE%\\.codex\\product-release-gate\\events",
  "runtime": {
    "state_dir": "%LOCALAPPDATA%\\product-release-gate\\state",
    "poll_minutes": 60,
    "scheduler_mode": "auto",
    "auto_authorize_verified_pre_release": false,
    "auto_deploy_authorized_releases": false,
    "auto_generate_production_report": false,
    "auto_deliver_production_report": false,
    "authorization_requester": "rd-flywheel"
  },
  "policy": {
    "allowed_extensions": [
      ".exe",
      ".dll",
      ".sys",
      ".msi",
      ".zip"
    ],
    "require_source_ref": true,
    "require_signature": true,
    "require_cloud_scan": true,
    "allow_unchanged_artifacts": false,
    "auto_approve_risk_levels": [
      "standard"
    ]
  },
  "signature": {
    "expected_thumbprints": [
      "REPLACE_WITH_40_HEX_CERTIFICATE_THUMBPRINT"
    ],
    "expected_subject_contains": ""
  },
  "cloud_scan": {
    "command": [
      "C:\\path\\to\\cloud-scan-adapter.exe",
      "--sha1",
      "{sha1}",
      "--json"
    ],
    "clean_verdict": "CLEAN",
    "timeout_seconds": 90
  },
  "test": {
    "command": [
      "C:\\path\\to\\test-orchestrator.exe",
      "--manifest",
      "{manifest_s_path}",
      "--json"
    ],
    "timeout_seconds": 3600
  },
  "production": {
    "enabled": false,
    "approval_workflow": {
      "mode": "legacy_external",
      "verify_command": [],
      "timeout_seconds": 120
    },
    "authorization": {
      "key_env": "PRODUCT_RELEASE_GATE_AUTH_KEY",
      "credential_target": "ProductReleaseGate/authorization/v1",
      "ttl_seconds": 3600,
      "verify_command": [
        "C:\\path\\to\\feishu-approval-adapter.exe",
        "verify",
        "--approval-ref",
        "{approval_ref}",
        "--event-id",
        "{event_id}",
        "--manifest-s-digest",
        "{manifest_s_digest}",
        "--manifest-r-digest",
        "{manifest_r_digest}",
        "--target-scope",
        "{target_scope}",
        "--json"
      ],
      "timeout_seconds": 120
    },
    "audit": {
      "key_env": "PRODUCT_RELEASE_GATE_AUDIT_KEY",
      "credential_target": "ProductReleaseGate/audit/v1"
    },
    "deployment": {
      "stages": [
        "preproduction",
        "production_canary",
        "production_full"
      ],
      "targets": {
        "preproduction": "env:preproduction",
        "production_canary": "env:production:canary",
        "production_full": "env:production:full"
      },
      "dependency_lock": "C:\\path\\to\\deployment-adapter.lock.json",
      "dependency_lock_sha256": "REPLACE_WITH_64_HEX_SHA256_OF_DEPLOYMENT_LOCK",
      "deploy_command": [
        "C:\\path\\to\\deployment-adapter.exe",
        "deploy",
        "--stage",
        "{stage}",
        "--target",
        "{target_ref}",
        "--manifest-r",
        "{manifest_r_path}",
        "--authorization",
        "{authorization_path}",
        "--idempotency-key",
        "{idempotency_key}",
        "--expected-digest",
        "{manifest_r_digest}",
        "--json"
      ],
      "verify_command": [
        "C:\\path\\to\\deployment-adapter.exe",
        "verify",
        "--stage",
        "{stage}",
        "--target",
        "{target_ref}",
        "--deployment-ref",
        "{deployment_ref}",
        "--rollback-ref",
        "{rollback_ref}",
        "--expected-digest",
        "{manifest_r_digest}",
        "--json"
      ],
      "rollback_command": [
        "C:\\path\\to\\deployment-adapter.exe",
        "rollback",
        "--stage",
        "{stage}",
        "--target",
        "{target_ref}",
        "--deployment-ref",
        "{deployment_ref}",
        "--rollback-ref",
        "{rollback_ref}",
        "--json"
      ],
      "rollback_verify_command": [
        "C:\\path\\to\\deployment-adapter.exe",
        "verify-rollback",
        "--stage",
        "{stage}",
        "--target",
        "{target_ref}",
        "--deployment-ref",
        "{deployment_ref}",
        "--rollback-ref",
        "{rollback_ref}",
        "--restored-ref",
        "{restored_ref}",
        "--rollback-receipt-ref",
        "{rollback_receipt_ref}",
        "--json"
      ],
      "timeout_seconds": 900
    },
    "readback": {
      "command": [
        "C:\\path\\to\\deployment-adapter.exe",
        "readback",
        "--target",
        "{target_ref}",
        "--expected-digest",
        "{manifest_r_digest}",
        "--json"
      ],
      "timeout_seconds": 180
    },
    "report_delivery": {
      "enabled": false,
      "profile": "release-mail",
      "sender_email": "release-bot@example.com",
      "recipients": [
        "release-report-group@example.com"
      ],
      "module": "all",
      "mailbox": "INBOX",
      "dependency_lock": "C:\\path\\to\\dependency-lock.product-release-gate.json",
      "dependency_lock_sha256": "REPLACE_WITH_64_HEX_SHA256_OF_PLUGIN_DEPENDENCY_LOCK",
      "command": [
        "C:\\Python313\\python.exe",
        "C:\\path\\to\\plugins\\imap-smtp-mail\\src\\imap_smtp_mail_cli.py"
      ],
      "timeout_seconds": 120,
      "readback_timeout_seconds": 86400
    }
  }
}
